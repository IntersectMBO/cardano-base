{
    "$id": "https://raw.githubusercontent.com/IntersectMBO/cardano-base/master/cardano-config/schemas/StorageConfig.schema.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "description": "StorageConfiguration",
    "properties": {
        "DatabasePath": {
            "anyOf": [
                {
                    "format": "path",
                    "title": "String",
                    "type": "string"
                },
                {
                    "description": "SplitDB",
                    "properties": {
                        "ImmutablePath": {
                            "description": "Directory for the immutable database",
                            "format": "path",
                            "title": "ImmutablePath",
                            "type": "string"
                        },
                        "VolatilePath": {
                            "description": "Directory for the volatile database",
                            "format": "path",
                            "title": "VolatilePath",
                            "type": "string"
                        }
                    },
                    "required": [
                        "VolatilePath",
                        "ImmutablePath"
                    ],
                    "title": "Object",
                    "type": "object"
                }
            ],
            "default": "mainnet/db",
            "description": "Directory (or split directories) where the state is stored",
            "title": "DatabasePath"
        },
        "LedgerDB": {
            "description": "The LedgerDB configuration\nLedgerDB",
            "properties": {
                "Backend": {
                    "default": "V2InMemory",
                    "description": "Which LedgerDB backend to use (V2InMemory or V2LSM)",
                    "title": "Backend",
                    "type": "string"
                },
                "LSMDatabasePath": {
                    "description": "Custom path to the LSM database (V2LSM only)",
                    "format": "path",
                    "title": "LSMDatabasePath",
                    "type": "string"
                },
                "LSMExportPath": {
                    "description": "Directory into which the LSM backend exports snapshots (V2LSM only)",
                    "format": "path",
                    "title": "LSMExportPath",
                    "type": "string"
                },
                "QueryBatchSize": {
                    "default": 100000,
                    "description": "Chunk size for large backend reads",
                    "maximum": 1.8446744073709551615e19,
                    "minimum": 0,
                    "title": "QueryBatchSize",
                    "type": "integer"
                },
                "Snapshots": {
                    "anyOf": [
                        {
                            "const": "Mithril",
                            "title": "Mithril",
                            "type": "string"
                        },
                        {
                            "description": "SnapshotOptions",
                            "properties": {
                                "MaxDelay": {
                                    "description": "Upper bound (seconds) of the random snapshot delay",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "MaxDelay",
                                    "type": "integer"
                                },
                                "MinDelay": {
                                    "description": "Lower bound (seconds) of the random snapshot delay",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "MinDelay",
                                    "type": "integer"
                                },
                                "NumOfDiskSnapshots": {
                                    "description": "How many snapshots to keep on disk",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "NumOfDiskSnapshots",
                                    "type": "integer"
                                },
                                "RateLimit": {
                                    "description": "Minimum seconds between snapshots",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "RateLimit",
                                    "type": "integer"
                                },
                                "SlotOffset": {
                                    "description": "Slot at which the snapshot schedule is anchored",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "SlotOffset",
                                    "type": "integer"
                                },
                                "SnapshotInterval": {
                                    "description": "Slots between snapshots (non-zero)",
                                    "maximum": 1.8446744073709551615e19,
                                    "minimum": 0,
                                    "title": "SnapshotInterval",
                                    "type": "integer"
                                }
                            },
                            "title": "Object",
                            "type": "object"
                        }
                    ],
                    "default": "Mithril",
                    "description": "Snapshot policy: \"Mithril\" or an object of snapshot options",
                    "title": "Snapshots"
                }
            },
            "title": "LedgerDB",
            "type": "object"
        }
    },
    "title": "StorageConfig",
    "type": "object"
}
